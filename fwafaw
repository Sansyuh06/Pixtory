        error_surface = font.render(error_text, True, (255, 100, 100))
        screen.blit(error_surface, (20, HEIGHT - 40))

def main():
    global camera_rot, zoom, time_factor, camera_distance
    global simulation_phase, total_simulation_time, disruption_started
    
    clock = pygame.time.Clock()
    running = True
    paused = False
    dragging = False
    
    # Initialize optimized objects
    star = RealisticStar(initial_distance=600)
    accretion_disk = RealisticAccretionDisk()
    
    # Initialize background
    init_background_stars()
    
    print("GARGANTUA - Optimized Realistic Stellar Tidal Disruption Simulation")
    print(f"Black hole mass: {BH_MASS/M_sun/1e6:.1f} million solar masses")
    print(f"Initial star: {star.mass_sim:.1f} M☉, {star.temperature:.0f} K")
    
    # Performance tracking
    frame_times = []
    
    while running:
        frame_start = pygame.time.get_ticks()
        
        dt = clock.tick(60) / 1000.0
        dt = min(dt, 0.02)  # Cap for stability
        
        # Handle events
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    running = False
                elif event.key == pygame.K_SPACE:
                    paused = not paused
                elif event.key == pygame.K_r:
                    # Reset simulation
                    star = RealisticStar(initial_distance=600)
                    accretion_disk = RealisticAccretionDisk()
                    simulation_phase = 0
                    total_simulation_time = 0
                    disruption_started = False
                    # Clear caches
                    _color_cache.clear()
                    _ui_surfaces.clear()
                elif event.key == pygame.K_w:
                    camera_distance = max(300, camera_distance - 40)
                elif event.key == pygame.K_s:
                    camera_distance = min(1200, camera_distance + 40)
                elif event.key == pygame.K_a:
                    camera_rot[1] -= 0.08
                elif event.key == pygame.K_d:
                    camera_rot[1] += 0.08
            
            elif event.type == pygame.MOUSEBUTTONDOWN:
                if event.button == 1:
                    dragging = True
                    pygame.mouse.get_rel()
                elif event.button == 4:  # Scroll up
                    zoom = min(2.5, zoom * 1.08)
                elif event.button == 5:  # Scroll down
                    zoom = max(0.6, zoom / 1.08)
            
            elif event.type == pygame.MOUSEBUTTONUP:
                if event.button == 1:
                    dragging = False
            
            elif event.type == pygame.MOUSEMOTION:
                if dragging:
                    dx, dy = pygame.mouse.get_rel()
                    sensitivity = 0.004
                    camera_rot[1] += dx * sensitivity
                    camera_rot[0] += dy * sensitivity
                    camera_rot[0] = max(-0.8, min(0.8, camera_rot[0]))
        
        # Update simulation
        if not paused:
            time_factor += dt
            total_simulation_time += dt
            
            # Slow automatic rotation
            camera_rot[1] += 0.002 * dt
            
            # Update star
            if star:
                star_survives = star.update(dt)
                
                # Transfer debris to disk efficiently
                if star.is_disrupted and len(star.debris_particles) > 20:
                    transfer_rate = min(3, len(star.debris_particles) // 10)
                    for _ in range(transfer_rate):
                        if star.debris_particles:
                            debris = star.debris_particles.pop(0)
                            pos = (debris['x'], debris['y'], debris['z'])
                            vel = (debris['vx'], debris['vy'], debris['vz'])
                            accretion_disk.add_stellar_debris(debris['mass'], pos, vel)
                
                # Check if star consumed
                if not star_survives or star.distance <= EVENT_HORIZON_RADIUS * 1.02:
                    if star:
                        print(f"Star completely disrupted! Final mass disrupted: {star.total_disrupted_mass/star.mass_sim*100:.1f}%")
                        star = None
                        simulation_phase = 3
            
            # Update disk
            accretion_disk.update(dt)
            
            # Update phases
            if simulation_phase == 0 and star and star.distance < star.roche_limit * 2:
                simulation_phase = 1
            elif simulation_phase == 1 and disruption_started:
                simulation_phase = 2
        
        # Render scene
        screen.fill(SPACE_BLACK)
        
        # Draw optimized components
        draw_optimized_background()
        accretion_disk.draw()
        
        if star:
            star.draw()
        
        draw_black_hole()
        draw_optimized_ui(star, accretion_disk)
        
        # Performance info
        fps = clock.get_fps()
        fps_color = (100, 255, 100) if fps > 50 else (255, 255, 100) if fps > 35 else (255, 100, 100)
        fps_text = small_font.render(f"FPS: {fps:.0f}", True, fps_color)
        screen.blit(fps_text, (WIDTH - 60, 10))
        
        status_color = (100, 255, 100) if not paused else (255, 150, 100)
        status_text = "RUNNING" if not paused else "PAUSED"
        status_surface = small_font.render(status_text, True, status_color)
        screen.blit(status_surface, (WIDTH - 60, 25))
        
        # Frame time tracking
        frame_end = pygame.time.get_ticks()
        frame_time = frame_end - frame_start
        frame_times.append(frame_time)
        if len(frame_times) > 60:
            frame_times.pop(0)
        
        avg_frame_time = sum(frame_times) / len(frame_times)
        if avg_frame_time > 0:
            perf_text = small_font.render(f"{avg_frame_time:.1f}ms", True, (150, 150, 255))
            screen.blit(perf_text, (WIDTH - 60, 40))
        
        pygame.display.flip()
    
    pygame.quit()
    print("Gargantua simulation complete!")

if __name__ == "__main__":
    main()