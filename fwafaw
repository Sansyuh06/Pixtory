            total_debris = len(star_obj.debris_particles)
        else:
            star_distance_au = 0
            star_distance_rs = 0
            tidal_force_ratio = 0
            disrupted_mass_frac = 100
            time_dilation = 0
            total_debris = 0
        
        disk_mass_solar = disk_obj.total_mass
        disk_particle_count = len(disk_obj.particles)
        
        # Essential info only
        info_lines = [
            f"PHASE: {phase_names[current_phase]}",
            f"Time: {total_simulation_time:.1f}s",
            "",
            "STELLAR DATA:",
            f"Distance: {star_distance_au:.2f} AU" if star_obj else "Star: CONSUMED",
            f"Tidal Force: {tidal_force_ratio:.1f}x" if star_obj else "Tidal Force: ∞",
            f"Disrupted: {disrupted_mass_frac:.1f}%" if star_obj else "Disrupted: 100%",
            f"Time Dilation: {time_dilation:.2f}" if star_obj else "Time Dilation: 0",
            f"Debris: {total_debris}",
            "",
            "ACCRETION DISK:",
            f"Mass: {disk_mass_solar:.4f} M☉",
            f"Particles: {disk_particle_count}",
            "",
            "BLACK HOLE:",
            f"Mass: {BH_MASS/M_sun/1e6:.1f}M M☉",
            f"Rs: {SCHWARZSCHILD_RADIUS:.1e} AU",
            "",
            "CONTROLS:",
            "Mouse: Rotate Camera",
            "Scroll: Zoom",
            "WASD: Distance",
            "SPACE: Pause",
            "R: Reset",
            "ESC: Exit"
        ]
        
        # Render with reduced formatting
        panel_y = 75
        for line in info_lines:
            if not line.strip():
                panel_y += 8
                continue
            
            # Simplified coloring
            if line.startswith("PHASE:"):
                color = (255, 200, 100)
            elif line.startswith(("STELLAR", "ACCRETION", "BLACK HOLE", "CONTROLS")):
                color = (150, 200, 255)
            elif ":" in line:
                color = (200, 200, 200)
            else:
                color = (255, 220, 150)
            
            text_surface = font.render(line, True, color)
