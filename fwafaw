        if 'title' not in _ui_surfaces:
            title_text = "GARGANTUA - Realistic Tidal Disruption Event"
            subtitle_text = "Supermassive Black Hole • 4.1M☉ • Schwarzschild Metric"
            
            _ui_surfaces['title'] = title_font.render(title_text, True, (255, 220, 120))
            _ui_surfaces['subtitle'] = small_font.render(subtitle_text, True, (180, 180, 180))
        
        # Draw cached titles
        title_rect = _ui_surfaces['title'].get_rect(center=(WIDTH//2, 25))
        subtitle_rect = _ui_surfaces['subtitle'].get_rect(center=(WIDTH//2, 45))
        screen.blit(_ui_surfaces['title'], title_rect)
        screen.blit(_ui_surfaces['subtitle'], subtitle_rect)
        
        # Dynamic data
        phase_names = ["APPROACH", "DISRUPTION", "ACCRETION", "POST-DISRUPTION"]
        current_phase = min(3, simulation_phase)
        
        if star_obj:
            star_distance_au = star_obj.distance / SCALE_FACTOR
            star_distance_rs = star_obj.distance / (SCHWARZSCHILD_RADIUS * SCALE_FACTOR)
            tidal_force_ratio = star_obj.tidal_strength
            disrupted_mass_frac = star_obj.total_disrupted_mass / star_obj.mass_sim * 100
