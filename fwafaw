# Physical constants (realistic values in simulation units)
G = 6.67430e-11  # Gravitational constant
c = 299792458    # Speed of light
M_sun = 1.989e30 # Solar mass
R_sun = 6.96e8   # Solar radius
AU = 1.496e11    # Astronomical unit

# Black hole properties (4.1 million solar masses like Sgr A*)
BH_MASS = 4.1e6 * M_sun
BH_MASS_SIM = 1000  # Simulation units
SCHWARZSCHILD_RADIUS = (2 * G * BH_MASS) / (c * c) / AU  # in AU
EVENT_HORIZON_RADIUS = 40   # pixels
PHOTON_SPHERE_RADIUS = EVENT_HORIZON_RADIUS * 1.5
ISCO_RADIUS = EVENT_HORIZON_RADIUS * 3
SCALE_FACTOR = EVENT_HORIZON_RADIUS / SCHWARZSCHILD_RADIUS  # pixels per AU

# Camera system
camera_distance = 600
