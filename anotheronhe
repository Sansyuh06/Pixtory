import pygame
import math
import numpy as np
from OpenGL.GL import *
from OpenGL.GLU import *
from pygame.locals import *

# Initialize pygame
pygame.init()
width, height = 1200, 800
pygame.display.set_mode((width, height), DOUBLEBUF | OPENGL)
pygame.display.set_caption("Interactive Black Hole Simulation")

# Set up the perspective
gluPerspective(45, (width / height), 0.1, 100.0)

# Enable depth testing and lighting
glEnable(GL_DEPTH_TEST)
glEnable(GL_LIGHTING)
glEnable(GL_LIGHT0)
glLightfv(GL_LIGHT0, GL_POSITION, (5, 5, 5, 1))
glLightfv(GL_LIGHT0, GL_DIFFUSE, (1, 1, 1, 1))
glLightfv(GL_LIGHT0, GL_AMBIENT, (0.1, 0.1, 0.1, 1))

# Material properties
glMaterialfv(GL_FRONT, GL_DIFFUSE, (0.7, 0.7, 0.7, 1))
glMaterialfv(GL_FRONT, GL_SPECULAR, (1, 1, 1, 1))
glMaterialf(GL_FRONT, GL_SHININESS, 50)

# Black hole parameters
BLACK_HOLE_MASS = 10.0
SCHWARZSCHILD_RADIUS = 1.5  # Event horizon radius
SPHERE_OF_INFLUENCE = 15.0

# Gravitational constant (scaled for visualization)
G = 1.0

# Camera parameters
camera_pos = [0, 0, 20]
camera_target = [0, 0, 0]
camera_up = [0, 1, 0]
camera_speed = 0.2

# Function to update camera view
def update_camera():
    glLoadIdentity()
    gluLookAt(
        camera_pos[0], camera_pos[1], camera_pos[2],
        camera_target[0], camera_target[1], camera_target[2],
        camera_up[0], camera_up[1], camera_up[2]
    )

# Function to draw a sphere
def draw_sphere(radius, slices, stacks):
    quad = gluNewQuadric()
    gluSphere(quad, radius, slices, stacks)

# Function to draw a ring (accretion disk)
def draw_ring(inner_radius, outer_radius, segments):
    glBegin(GL_QUADS)
    for i in range(segments):
        angle = 2 * math.pi * i / segments
        next_angle = 2 * math.pi * (i + 1) / segments
        
        # Inner ring
        x1 = inner_radius * math.cos(angle)
        z1 = inner_radius * math.sin(angle)
        x2 = inner_radius * math.cos(next_angle)
        z2 = inner_radius * math.sin(next_angle)
        
        # Outer ring
        x3 = outer_radius * math.cos(next_angle)
        z3 = outer_radius * math.sin(next_angle)
        x4 = outer_radius * math.cos(angle)
        z4 = outer_radius * math.sin(angle)
        
        glVertex3f(x1, 0, z1)
        glVertex3f(x2, 0, z2)
        glVertex3f(x3, 0, z3)
        glVertex3f(x4, 0, z4)
    glEnd()

# Create stars in the background
stars = []
for _ in range(1000):
    star = (
        np.random.uniform(-50, 50),
        np.random.uniform(-50, 50),
        np.random.uniform(-50, -30)
    )
    stars.append(star)

# Particle system for accretion disk
class Particle:
    def __init__(self):
        angle = np.random.uniform(0, 2 * np.pi)
        distance = np.random.uniform(SCHWARZSCHILD_RADIUS * 2, SPHERE_OF_INFLUENCE * 0.7)
        height = np.random.uniform(-0.3, 0.3)
        self.pos = np.array([
            distance * np.cos(angle),
            height,
            distance * np.sin(angle)
        ])
        # Orbital velocity with some random perturbation
        orbital_speed = np.sqrt(G * BLACK_HOLE_MASS / distance) * 0.8
        self.vel = np.array([
            -orbital_speed * np.sin(angle) + np.random.uniform(-0.02, 0.02),
            np.random.uniform(-0.01, 0.01),
            orbital_speed * np.cos(angle) + np.random.uniform(-0.02, 0.02)
        ])
        self.life = np.random.uniform(0.8, 1.0)
        self.size = np.random.uniform(0.05, 0.15)
        self.color = (
            np.random.uniform(0.8, 1.0),
            np.random.uniform(0.4, 0.8),
            np.random.uniform(0.1, 0.3)
        )
        self.trail = []  # Store previous positions for trail effect
    
    def update(self):
        # Store current position for trail
        self.trail.append(self.pos.copy())
        if len(self.trail) > 8:
            self.trail.pop(0)
        
        # Calculate distance to black hole
        dist = np.linalg.norm(self.pos)
        
        # Apply gravitational force (Newtonian gravity)
        if dist > 0.1:
            force_magnitude = G * BLACK_HOLE_MASS / (dist ** 2)
            direction = -self.pos / dist
            acceleration = force_magnitude * direction
            self.vel += acceleration * 0.005
        
        # Update position
        self.pos += self.vel * 0.5
        
        # Update life
        self.life -= 0.002
        
        # Reset particles that get too close or too old
        if dist < SCHWARZSCHILD_RADIUS * 1.2 or self.life <= 0:
            self.reset()
    
    def reset(self):
        angle = np.random.uniform(0, 2 * np.pi)
        distance = np.random.uniform(SPHERE_OF_INFLUENCE * 0.6, SPHERE_OF_INFLUENCE * 0.8)
        height = np.random.uniform(-0.2, 0.2)
        self.pos = np.array([
            distance * np.cos(angle),
            height,
            distance * np.sin(angle)
        ])
        orbital_speed = np.sqrt(G * BLACK_HOLE_MASS / distance) * 0.8
        self.vel = np.array([
            -orbital_speed * np.sin(angle) + np.random.uniform(-0.01, 0.01),
            np.random.uniform(-0.005, 0.005),
            orbital_speed * np.cos(angle) + np.random.uniform(-0.01, 0.01)
        ])
        self.life = 1.0
        self.trail = []
    
    def draw(self):
        # Draw trail
        if len(self.trail) > 1:
            glColor4f(self.color[0], self.color[1], self.color[2], 0.3)
            glLineWidth(1.0)
            glBegin(GL_LINE_STRIP)
            for pos in self.trail:
                glVertex3fv(pos)
            glEnd()
        
        # Draw particle
        glColor4f(self.color[0] * self.life, self.color[1] * self.life, self.color[2] * self.life, self.life)
        glPushMatrix()
        glTranslatef(self.pos[0], self.pos[1], self.pos[2])
        draw_sphere(self.size, 8, 8)
        glPopMatrix()

# Create particles for accretion disk
particles = [Particle() for _ in range(600)]

# Function to draw the black hole with realistic effects
def draw_black_hole():
    # Event horizon (black sphere with slight glow)
    glPushMatrix()
    glColor4f(0, 0, 0, 1)
    draw_sphere(SCHWARZSCHILD_RADIUS, 40, 40)
    
    # Photon sphere (where light orbits the black hole)
    glColor4f(0.3, 0.6, 1.0, 0.2)
    glDisable(GL_LIGHTING)
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)
    draw_sphere(SCHWARZSCHILD_RADIUS * 1.5, 30, 30)
    glEnable(GL_LIGHTING)
    glDisable(GL_BLEND)
    glPopMatrix()
    
    # Accretion disk with color gradient
    glPushMatrix()
    glRotatef(90, 1, 0, 0)
    segments = 64
    inner_radius = SCHWARZSCHILD_RADIUS * 2.0
    outer_radius = SPHERE_OF_INFLUENCE * 0.6
    
    glBegin(GL_QUADS)
    for i in range(segments):
        angle = 2 * math.pi * i / segments
        next_angle = 2 * math.pi * (i + 1) / segments
        
        # Inner ring
        x1 = inner_radius * math.cos(angle)
        z1 = inner_radius * math.sin(angle)
        x2 = inner_radius * math.cos(next_angle)
        z2 = inner_radius * math.sin(next_angle)
        
        # Outer ring
        x3 = outer_radius * math.cos(next_angle)
        z3 = outer_radius * math.sin(next_angle)
        x4 = outer_radius * math.cos(angle)
        z4 = outer_radius * math.sin(angle)
        
        # Color gradient from inner (hot) to outer (cool)
        inner_ratio = (inner_radius - SCHWARZSCHILD_RADIUS) / (outer_radius - SCHWARZSCHILD_RADIUS)
        outer_ratio = 1.0
        
        # Inner color (hot orange)
        r1, g1, b1 = 1.0, 0.6, 0.2
        # Outer color (cool red)
        r2, g2, b2 = 0.8, 0.2, 0.1
        
        glColor4f(r1, g1, b1, 0.7)
        glVertex3f(x1, 0, z1)
        glVertex3f(x2, 0, z2)
        glColor4f(r2, g2, b2, 0.5)
        glVertex3f(x3, 0, z3)
        glVertex3f(x4, 0, z4)
    glEnd()
    glPopMatrix()
    
    # Draw particles
    for particle in particles:
        particle.draw()

# Function to draw the spacetime curvature visualization
def draw_spacetime_curvature():
    glColor4f(0.1, 0.3, 0.8, 0.2)
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)
    
    # Create a grid to represent spacetime curvature
    grid_size = 30
    grid_spacing = 1.0
    max_dist = grid_size * grid_spacing / 2
    
    for i in range(-grid_size//2, grid_size//2 + 1):
        for j in range(-grid_size//2, grid_size//2 + 1):
            x = i * grid_spacing
            z = j * grid_spacing
            dist = math.sqrt(x**2 + z**2)
            
            # Skip the center where the black hole is
            if dist < SCHWARZSCHILD_RADIUS * 1.5:
                continue
                
            # Calculate deformation based on distance to black hole (Schwarzschild metric)
            # Simplified for visualization purposes
            deformation = 1.0 / (1 + math.exp((dist - SCHWARZSCHILD_RADIUS) / 2.0))
            
            # Draw deformed grid
            glBegin(GL_QUADS)
            glVertex3f(x - 0.4, -deformation, z - 0.4)
            glVertex3f(x + 0.4, -deformation, z - 0.4)
            glVertex3f(x + 0.4, -deformation, z + 0.4)
            glVertex3f(x - 0.4, -deformation, z + 0.4)
            glEnd()
    
    glDisable(GL_BLEND)

# Function to draw background stars
def draw_stars():
    glColor3f(1, 1, 1)
    glPointSize(2.0)
    glBegin(GL_POINTS)
    for star in stars:
        glVertex3fv(star)
    glEnd()

# Function to draw a realistic accretion disk with color gradient
def draw_accretion_disk():
    glPushMatrix()
    glRotatef(90, 1, 0, 0)
    
    # Enable blending for transparency
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)
    
    segments = 128
    inner_radius = SCHWARZSCHILD_RADIUS * 2.0
    outer_radius = SPHERE_OF_INFLUENCE * 0.7
    
    glBegin(GL_QUAD_STRIP)
    for i in range(segments + 1):
        angle = 2 * math.pi * i / segments
        cos_a = math.cos(angle)
        sin_a = math.sin(angle)
        
        # Inner point
        x_inner = inner_radius * cos_a
        z_inner = inner_radius * sin_a
        
        # Outer point
        x_outer = outer_radius * cos_a
        z_outer = outer_radius * sin_a
        
        # Color based on temperature (inner hotter, outer cooler)
        # Inner: Blue-white (hot)
        # Outer: Red (cooler)
        t = i / segments
        r = 0.8 + 0.2 * math.sin(t * math.pi)
        g = 0.4 + 0.4 * math.cos(t * math.pi * 2)
        b = 0.8 + 0.2 * math.cos(t * math.pi)
        alpha = 0.7
        
        glColor4f(r, g, b, alpha)
        glVertex3f(x_inner, 0, z_inner)
        glVertex3f(x_outer, 0, z_outer)
    glEnd()
    
    glDisable(GL_BLEND)
    glPopMatrix()

# Function to draw gravitational lensing effect (simplified)
def draw_gravitational_lensing():
    glColor4f(0.5, 0.8, 1.0, 0.1)
    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)
    
    # Draw several concentric rings to represent lensing
    for i in range(5):
        radius = SCHWARZSCHILD_RADIUS * (2.0 + i * 0.5)
        glBegin(GL_LINE_LOOP)
        segments = 64
        for j in range(segments):
            angle = 2 * math.pi * j / segments
            x = radius * math.cos(angle)
            z = radius * math.sin(angle)
            y = 0.01 * math.sin(angle * 5)  # Slight wave for effect
            glVertex3f(x, y, z)
        glEnd()
    
    glDisable(GL_BLEND)

# Main loop
clock = pygame.time.Clock()
mouse_dragging = False
last_mouse_pos = (0, 0)
yaw = 0
pitch = 0

# Hide mouse cursor and set initial position
pygame.event.set_grab(True)
pygame.mouse.set_visible(False)
pygame.mouse.set_pos(width // 2, height // 2)

running = True
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_ESCAPE:
                running = False
            elif event.key == pygame.K_r:  # Reset view
                camera_pos = [0, 0, 20]
                yaw = 0
                pitch = 0
        elif event.type == pygame.MOUSEMOTION:
            # Mouse look
            if pygame.mouse.get_focused():
                dx, dy = event.rel
                yaw += dx * 0.2
                pitch += dy * 0.2
                
                # Limit pitch to avoid flipping
                if pitch > 90:
                    pitch = 90
                if pitch < -90:
                    pitch = -90
                
                # Update camera target based on yaw and pitch
                camera_target[0] = camera_pos[0] + math.sin(math.radians(yaw)) * math.cos(math.radians(pitch))
                camera_target[1] = camera_pos[1] + math.sin(math.radians(pitch))
                camera_target[2] = camera_pos[2] - math.cos(math.radians(yaw)) * math.cos(math.radians(pitch))
                
                # Reset mouse to center of screen
                pygame.mouse.set_pos(width // 2, height // 2)
    
    # Handle keyboard input for camera movement
    keys = pygame.key.get_pressed()
    if keys[pygame.K_w]:  # Move forward
        camera_pos[0] += math.sin(math.radians(yaw)) * camera_speed
        camera_pos[2] -= math.cos(math.radians(yaw)) * camera_speed
        camera_target[0] += math.sin(math.radians(yaw)) * camera_speed
        camera_target[2] -= math.cos(math.radians(yaw)) * camera_speed
    if keys[pygame.K_s]:  # Move backward
        camera_pos[0] -= math.sin(math.radians(yaw)) * camera_speed
        camera_pos[2] += math.cos(math.radians(yaw)) * camera_speed
        camera_target[0] -= math.sin(math.radians(yaw)) * camera_speed
        camera_target[2] += math.cos(math.radians(yaw)) * camera_speed
    if keys[pygame.K_a]:  # Strafe left
        camera_pos[0] -= math.cos(math.radians(yaw)) * camera_speed
        camera_pos[2] -= math.sin(math.radians(yaw)) * camera_speed
        camera_target[0] -= math.cos(math.radians(yaw)) * camera_speed
        camera_target[2] -= math.sin(math.radians(yaw)) * camera_speed
    if keys[pygame.K_d]:  # Strafe right
        camera_pos[0] += math.cos(math.radians(yaw)) * camera_speed
        camera_pos[2] += math.sin(math.radians(yaw)) * camera_speed
        camera_target[0] += math.cos(math.radians(yaw)) * camera_speed
        camera_target[2] += math.sin(math.radians(yaw)) * camera_speed
    if keys[pygame.K_q]:  # Move up
        camera_pos[1] += camera_speed
        camera_target[1] += camera_speed
    if keys[pygame.K_e]:  # Move down
        camera_pos[1] -= camera_speed
        camera_target[1] -= camera_speed
    
    # Update particles
    for particle in particles:
        particle.update()
    
    # Clear the screen
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
    
    # Update camera
    update_camera()
    
    # Draw background stars
    draw_stars()
    
    # Draw spacetime curvature
    draw_spacetime_curvature()
    
    # Draw gravitational lensing effect
    draw_gravitational_lensing()
    
    # Draw accretion disk
    draw_accretion_disk()
    
    # Draw black hole
    draw_black_hole()
    
    pygame.display.flip()
    clock.tick(60)

pygame.quit()